# ── Server Configuration ──

# Port for the signaling + SFU server (Render sets this automatically)
PORT=8080

# Public IP address for mediasoup WebRTC transports.
# On cloud deployments (Render, AWS, etc.), the server is behind NAT —
# mediasoup needs to know the public IP so clients can connect.
# If not set, the server auto-detects via api.ipify.org at startup.
# ANNOUNCED_IP=203.0.113.10

# ── TURN Server ──
# ⚠️  REQUIRED for cloud platforms (Render, Railway, Vercel, etc.) that only
# expose a single HTTP port. Without TURN, mediasoup's UDP/TCP media ports
# (40000+) are firewalled and WebRTC media transport WILL FAIL.
#
# Free options:
#   - Metered TURN (https://www.metered.ca/stun-turn) — free tier available
#   - Cloudflare Calls TURN — free tier
#   - Self-hosted coturn on a VPS with open UDP ports
#
# Multiple TURN URLs can be comma-separated:
# TURN_URLS=turn:a.relay.metered.ca:80,turn:a.relay.metered.ca:443,turns:a.relay.metered.ca:443
TURN_URLS=turn:a.relay.metered.ca:80
TURN_USERNAME=your-metered-api-key
TURN_CREDENTIAL=your-metered-api-secret
